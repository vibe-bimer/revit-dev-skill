# Copy to a private file (NOT committed), e.g. ~/.config/revit-skill.env
# Then load it before running commands from docs:
# source ~/.config/revit-skill.env

# Network placeholders (replace with your private values)
export REVIT_WINDOWS_HOST=<REVIT_WINDOWS_HOST>
export GITLAB_HOST=<GITLAB_HOST>
export DEV_HOST=<DEV_HOST>
export UNRAID_BR1_SRC=<UNRAID_BR1_SRC>

# Optional secrets (private only, do NOT commit)
export WINDOWS_USER=<WINDOWS_USER>
export WINDOWS_PASSWORD=<WINDOWS_PASSWORD>
export GITLAB_TOKEN=<GITLAB_TOKEN>
